\Search.tsx",["45"],"import { IonButton, IonCard, IonInput, IonSelect, IonSelectOption } from '@ionic/react';\r\nimport React, { useCallback, useEffect, useState } from 'react';\r\nimport './Search.css';\r\n\r\nconst Search: React.FC<{ onSearch }> = ({ onSearch }) => {\r\n  const [text, setText] = useState<string>('');\r\n  const [placeholder, setPlaceholder] = useState<string>('Search User');\r\n  const [searchType, setSearchType] = useState<string>('user');\r\n  const [searchTime, setSearchTime] = useState<string>('last-week');\r\n\r\n  const timeChangeHander = useCallback(() => {\r\n    if (text.trim()) {\r\n      onSearch(text, searchType, searchTime);\r\n    }\r\n  }, [text, searchType, searchTime, onSearch]);\r\n\r\n  const enterHandler = useCallback(\r\n    event => {\r\n      if (text.trim() && event.key === 'Enter') {\r\n        onSearch(text, searchType, searchTime);\r\n      }\r\n    },\r\n    [text, searchType, searchTime, onSearch]\r\n  );\r\n\r\n  useEffect(() => {\r\n    timeChangeHander();\r\n  }, [searchTime]);\r\n\r\n  return (\r\n    <div className=\"search\">\r\n      <IonCard>\r\n        <div className=\"search__row\">\r\n          <IonInput\r\n            value={text}\r\n            placeholder={placeholder}\r\n            onIonChange={e => setText(e.detail.value!)}\r\n            onKeyPress={enterHandler}\r\n          ></IonInput>\r\n          <IonButton\r\n            className=\"search__button\"\r\n            color=\"primary\"\r\n            onClick={e => onSearch(text, searchType, searchTime)}\r\n          >\r\n            Search\r\n          </IonButton>\r\n        </div>\r\n        <div className=\"search__row\">\r\n          <IonSelect\r\n            className=\"search__select\"\r\n            value={searchType}\r\n            okText=\"Okay\"\r\n            cancelText=\"Dismiss\"\r\n            onIonChange={e => {\r\n              setSearchType(e.detail.value);\r\n              setPlaceholder(e.detail.value === 'user' ? 'Search User' : 'Search Package');\r\n            }}\r\n          >\r\n            <IonSelectOption value=\"user\">User</IonSelectOption>\r\n            <IonSelectOption value=\"package\">Package</IonSelectOption>\r\n          </IonSelect>\r\n          <IonSelect\r\n            className=\"search__select\"\r\n            value={searchTime}\r\n            okText=\"Okay\"\r\n            cancelText=\"Dismiss\"\r\n            onIonChange={e => setSearchTime(e.detail.value)}\r\n          >\r\n            <IonSelectOption value=\"last-day\">Last Day</IonSelectOption>\r\n            <IonSelectOption value=\"last-week\">Last Week</IonSelectOption>\r\n            <IonSelectOption value=\"last-month\">Last Month</IonSelectOption>\r\n            <IonSelectOption value=\"last-year\">Last Year</IonSelectOption>\r\n          </IonSelect>\r\n        </div>\r\n      </IonCard>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Search;\r\n","D:\\projects\\js\\npm-stats\\src\\utils\\victoryTheme.ts",[],"D:\\projects\\js\\npm-stats\\src\\utils\\handleFetchErrors.ts",[],{"ruleId":"46","replacedBy":"47"},{"ruleId":"48","replacedBy":"49"},{"ruleId":"50","severity":1,"message":"51","line":2,"column":10,"nodeType":"52","messageId":"53","endLine":2,"endColumn":18},{"ruleId":"50","severity":1,"message":"54","line":11,"column":36,"nodeType":"52","messageId":"53","endLine":11,"endColumn":48},{"ruleId":"55","severity":1,"message":"56","line":28,"column":6,"nodeType":"57","endLine":28,"endColumn":18,"suggestions":"58"},"no-native-reassign",["59"],"no-negated-in-lhs",["60"],"@typescript-eslint/no-unused-vars","'Redirect' is defined but never used.","Identifier","unusedVar","'VictoryTheme' is defined but never used.","react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'timeChangeHander'. Either include it or remove the dependency array.","ArrayExpression",["61"],"no-global-assign","no-unsafe-negation",{"desc":"62","fix":"63"},"Update the dependencies array to be: [searchTime, timeChangeHa